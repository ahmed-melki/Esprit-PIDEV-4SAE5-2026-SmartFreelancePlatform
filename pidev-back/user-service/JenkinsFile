pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk 'JDK-17'
    }

    environment {
        SERVICE_NAME = 'user-service'
        DOCKER_REGISTRY = 'myregistry'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package -DskipTests'
            }
            post {
                success {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Docker Build') {
            when { branch 'main' }
            steps {
                sh "docker build -t ${SERVICE_NAME}:${BUILD_NUMBER} ."
                sh "docker tag ${SERVICE_NAME}:${BUILD_NUMBER} ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest"
                sh "docker push ${DOCKER_REGISTRY}/${SERVICE_NAME}:latest"
            }
        }

        stage('Deploy') {
            when { branch 'main' }
            steps {
                echo "Déploiement de ${SERVICE_NAME}"
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo "Pipeline échoué pour ${SERVICE_NAME}"
        }
    }
}