pipeline {
    agent any
    environment {
        DOCKER_IMAGE = 'ahmedmelki/smartfreelance-frontend'
        DOCKER_TAG   = "1.0.${BUILD_NUMBER}"
    }
    stages {
        stage('Checkout') {
            steps {
                echo "Cloning frontend repository..."
                checkout scm
            }
        }
        stage('Build Docker Image') {
            steps {
                echo "Building Angular + Docker image..."
                bat "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                bat "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
            }
        }
        stage('Push to DockerHub') {
            steps {
                echo "Pushing to DockerHub..."
                withCredentials([usernamePassword(
                    credentialsId: 'student-management-docker',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat "docker login -u %DOCKER_USER% -p %DOCKER_PASS%"
                    bat "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    bat "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }
        stage('Test Docker Image') {
            steps {
                echo "Testing Docker image..."
                bat "docker run --rm ${DOCKER_IMAGE}:latest nginx -v"
            }
        }
        stage('Trigger CD Pipeline') {
            steps {
                echo "Triggering Frontend CD pipeline..."
                build job: 'smartfreelance-frontend-cd', wait: false
            }
        }
    }
    post {
        success { echo "✅ smartfreelance-frontend CI SUCCESS — build #${BUILD_NUMBER}" }
        failure { echo "❌ smartfreelance-frontend CI FAILED" }
        always { bat "docker logout" }
    }
}
