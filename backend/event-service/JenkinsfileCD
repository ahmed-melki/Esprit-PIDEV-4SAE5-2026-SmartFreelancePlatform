pipeline {
    agent any
    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'blog+event',
                    url: 'https://github.com/ahmed-melki/Esprit-PIDEV-4SAE5-2026-SmartFreelancePlatform.git'
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f backend/event-service/mysql-deployment.yaml'
                sh 'kubectl apply -f backend/event-service/deployment.yaml'
                sh 'kubectl apply -f backend/event-service/service.yaml'
                sh 'kubectl rollout status deployment/mysql --timeout=300s'
                sh 'kubectl rollout status deployment/gestion-event --timeout=120s'
            }
        }
        stage('Verify Deployment') {
            steps {
                sh 'kubectl get pods -l app=gestion-event'
                sh 'kubectl get service gestion-event-service'
            }
        }
    }
    post {
        success {
            echo 'CD SUCCESS'
        }
        failure {
            echo 'CD FAILED'
        }
    }
}